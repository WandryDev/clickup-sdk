{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "declaration": true,
    "noEmit": true
  },
  "include": ["src", "openapi-ts.config.ts", "scripts", "tsup.config.ts"],
  "exclude": ["node_modules", "dist"]
}
