{
  "name": "@wandrydev/clickup",
  "version": "0.2.0",
  "description": "Typed ClickUp API client (generated from ClickUp's OpenAPI specs) with an injectable logger.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WandryDev/clickup-sdk.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check",
    "format": "biome format --write",
    "clickup:types": "tsx scripts/preprocess-clickup-openapi.ts && openapi-ts",
    "prepublishOnly": "bun run build",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@changesets/cli": "^2.31.0",
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "0.96.1",
    "@types/node": "^20",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
